<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Portal — Start Your Cause</title>
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --cream:#fdf8f2;--warm:#fff9f4;--sand:#f0e9de;--sand2:#e2d5c6;
  --green:#2d8f6f;--gdark:#1d6b52;--glight:#e8f5ef;--gmid:#c4e8d8;
  --amber:#e07b39;--amberL:#fdf0e6;
  --text:#2c2418;--tmid:#6b5c4c;--tlight:#9e8e7e;
  --r:14px;--rs:8px;--red:#e05555;--redL:#fff0f0;
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text);font-size:16px;line-height:1.7;min-height:100vh}
h1,h2,h3,h4{font-family:'Lora',serif;line-height:1.25}
a{color:var(--green);text-decoration:none}

/* ── LAYOUT ── */
.app{display:flex;min-height:100vh}
.sidebar{width:240px;background:var(--gdark);color:#fff;flex-shrink:0;display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100}
.main{margin-left:240px;flex:1;min-height:100vh}
@media(max-width:768px){.sidebar{transform:translateX(-100%);transition:transform .3s}.sidebar.open{transform:translateX(0)}.main{margin-left:0}}

/* ── SIDEBAR ── */
.sb-logo{padding:1.5rem;border-bottom:1px solid rgba(255,255,255,.1);font-family:'Lora',serif;font-size:17px;font-weight:600;display:flex;align-items:center;gap:8px}
.sb-nav{flex:1;padding:1rem 0;overflow-y:auto}
.sb-item{display:flex;align-items:center;gap:10px;padding:10px 1.25rem;cursor:pointer;font-size:14px;font-weight:400;color:rgba(255,255,255,.75);transition:all .15s;border:none;background:none;width:100%;text-align:left;font-family:'DM Sans',sans-serif}
.sb-item:hover{background:rgba(255,255,255,.1);color:#fff}
.sb-item.active{background:rgba(255,255,255,.15);color:#fff;font-weight:500}
.sb-item .icon{font-size:17px;width:22px;text-align:center;flex-shrink:0}
.sb-section{font-size:10px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4);padding:.75rem 1.25rem .25rem}
.sb-org{padding:1rem 1.25rem;border-top:1px solid rgba(255,255,255,.1);font-size:13px;color:rgba(255,255,255,.6)}
.sb-org strong{display:block;color:#fff;font-size:14px;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sb-signout{display:flex;align-items:center;gap:8px;padding:10px 1.25rem;cursor:pointer;font-size:13px;color:rgba(255,255,255,.6);border:none;background:none;width:100%;font-family:'DM Sans',sans-serif;transition:color .15s}
.sb-signout:hover{color:#fff}

/* ── TOP BAR ── */
.topbar{background:var(--warm);border-bottom:1px solid var(--sand2);padding:0 2rem;height:60px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}
.topbar h1{font-size:18px;font-family:'Lora',serif;color:var(--text)}
.mob-toggle{display:none;background:none;border:none;font-size:22px;cursor:pointer;color:var(--text)}
@media(max-width:768px){.mob-toggle{display:block}}
.topbar-right{display:flex;align-items:center;gap:.75rem}
.badge{display:inline-block;font-size:11px;font-weight:500;padding:3px 10px;border-radius:20px}
.badge-green{background:var(--glight);color:var(--gdark);border:1px solid var(--gmid)}
.badge-amber{background:var(--amberL);color:#7a4010;border:1px solid #f5cfa8}
.badge-red{background:var(--redL);color:var(--red);border:1px solid #f5c0c0}

/* ── PAGES ── */
.portal-page{display:none;padding:2rem}
.portal-page.active{display:block}

/* ── AUTH SCREENS ── */
#auth-screen{display:flex;align-items:center;justify-content:center;min-height:100vh;background:var(--cream);padding:2rem}
.auth-card{background:var(--warm);border:1px solid var(--sand2);border-radius:var(--r);padding:2.5rem;max-width:440px;width:100%;box-shadow:0 4px 24px rgba(44,36,24,.08)}
.auth-logo{text-align:center;margin-bottom:2rem}
.auth-logo .leaf{font-size:36px}
.auth-logo h1{font-size:1.5rem;color:var(--gdark);margin-top:.5rem}
.auth-logo p{font-size:14px;color:var(--tmid);margin-top:.25rem}
.auth-tabs{display:flex;border-bottom:1px solid var(--sand2);margin-bottom:1.5rem}
.auth-tab{flex:1;padding:.75rem;text-align:center;cursor:pointer;font-size:14px;font-weight:500;color:var(--tlight);border:none;background:none;font-family:'DM Sans',sans-serif;border-bottom:2px solid transparent;transition:all .15s}
.auth-tab.active{color:var(--green);border-bottom-color:var(--green)}
.field{margin-bottom:1rem}
.field label{display:block;font-size:13px;font-weight:500;color:var(--text);margin-bottom:4px}
.field input{width:100%;padding:10px 13px;border:1.5px solid var(--sand2);border-radius:var(--rs);font-size:15px;font-family:'DM Sans',sans-serif;color:var(--text);background:#fff;transition:border-color .15s}
.field input:focus{outline:none;border-color:var(--green);box-shadow:0 0 0 3px rgba(45,143,111,.1)}
.btn-full{width:100%;padding:12px;border-radius:var(--rs);font-size:15px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s;border:none}
.btn-green{background:var(--green);color:#fff}
.btn-green:hover{background:var(--gdark)}
.btn-google{background:#fff;color:var(--text);border:1.5px solid var(--sand2);display:flex;align-items:center;justify-content:center;gap:10px;margin-top:.75rem}
.btn-google:hover{background:var(--sand)}
.divider{display:flex;align-items:center;gap:.75rem;margin:1rem 0;color:var(--tlight);font-size:13px}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--sand2)}
.auth-error{background:var(--redL);border:1px solid #f5c0c0;border-radius:var(--rs);padding:.75rem 1rem;font-size:13px;color:var(--red);margin-bottom:1rem;display:none}
.auth-success{background:var(--glight);border:1px solid var(--gmid);border-radius:var(--rs);padding:.75rem 1rem;font-size:13px;color:var(--gdark);margin-bottom:1rem;display:none}

/* ── CARDS ── */
.card{background:var(--warm);border:1px solid var(--sand2);border-radius:var(--r);padding:1.5rem;margin-bottom:1.25rem}
.card-title{font-size:16px;font-family:'Lora',serif;margin-bottom:.75rem;display:flex;align-items:center;gap:.5rem}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.25rem}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}
@media(max-width:900px){.grid-4{grid-template-columns:1fr 1fr}.grid-3{grid-template-columns:1fr 1fr}}
@media(max-width:600px){.grid-2,.grid-3,.grid-4{grid-template-columns:1fr}}

/* ── STAT CARDS ── */
.stat-card{background:var(--warm);border:1px solid var(--sand2);border-radius:var(--r);padding:1.25rem;text-align:center}
.stat-num{font-family:'Lora',serif;font-size:2rem;font-weight:600;color:var(--gdark);display:block}
.stat-label{font-size:13px;color:var(--tlight);margin-top:2px}

/* ── PROGRESS ── */
.progress-bar{height:8px;background:var(--sand2);border-radius:4px;overflow:hidden;margin:.5rem 0}
.progress-fill{height:100%;background:var(--green);border-radius:4px;transition:width .4s}

/* ── DOC CARDS ── */
.doc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.875rem}
.doc-card{background:var(--warm);border:1px solid var(--sand2);border-radius:var(--rs);padding:1.125rem;cursor:pointer;transition:border-color .15s,box-shadow .15s;position:relative}
.doc-card:hover{border-color:var(--gmid);box-shadow:0 2px 12px rgba(45,143,111,.1)}
.doc-card.locked{opacity:.6;cursor:default}
.doc-icon{font-size:24px;margin-bottom:.5rem;display:block}
.doc-card h4{font-size:13px;font-weight:500;margin-bottom:.2rem;font-family:'DM Sans',sans-serif}
.doc-card p{font-size:12px;color:var(--tlight);line-height:1.4}
.doc-badge{display:inline-block;font-size:10px;background:var(--glight);color:var(--gdark);padding:2px 8px;border-radius:10px;margin-top:.4rem;font-weight:500}
.lock-icon{position:absolute;top:.75rem;right:.75rem;font-size:14px;color:var(--tlight)}

/* ── REMINDERS ── */
.reminder-item{display:flex;align-items:flex-start;gap:1rem;padding:1rem;background:var(--warm);border:1px solid var(--sand2);border-radius:var(--rs);margin-bottom:.75rem;transition:border-color .15s}
.reminder-item.overdue{border-color:#f5c0c0;background:var(--redL)}
.reminder-item.upcoming-soon{border-color:#f5cfa8;background:var(--amberL)}
.reminder-item.completed{opacity:.5}
.reminder-date{min-width:70px;text-align:center;background:var(--cream);border-radius:var(--rs);padding:.5rem;border:1px solid var(--sand2)}
.reminder-date .day{font-size:1.5rem;font-family:'Lora',serif;font-weight:600;color:var(--gdark);line-height:1;display:block}
.reminder-date .month{font-size:11px;color:var(--tlight);text-transform:uppercase;letter-spacing:.05em}
.reminder-content{flex:1}
.reminder-content h4{font-size:14px;font-weight:500;margin-bottom:2px;font-family:'DM Sans',sans-serif}
.reminder-content p{font-size:13px;color:var(--tmid)}
.reminder-actions{display:flex;gap:.5rem;margin-top:.5rem}
.btn-sm{padding:5px 12px;border-radius:6px;font-size:12px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;border:none;transition:all .15s}
.btn-sm-green{background:var(--glight);color:var(--gdark)}
.btn-sm-green:hover{background:var(--gmid)}
.btn-sm-ghost{background:transparent;color:var(--tlight);border:1px solid var(--sand2)}
.btn-sm-ghost:hover{background:var(--sand)}

/* ── CALENDAR ── */
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-top:.75rem}
.cal-header{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-bottom:4px}
.cal-header span{text-align:center;font-size:11px;font-weight:500;color:var(--tlight)}
.cal-day{aspect-ratio:1;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px;cursor:pointer;position:relative;transition:background .15s}
.cal-day:hover{background:var(--sand)}
.cal-day.today{background:var(--glight);color:var(--gdark);font-weight:600}
.cal-day.has-event::after{content:'';position:absolute;bottom:3px;left:50%;transform:translateX(-50%);width:4px;height:4px;border-radius:50%;background:var(--amber)}
.cal-day.other-month{color:var(--tlight)}
.cal-day.has-overdue::after{background:var(--red)}

/* ── PROFILE FORM ── */
.profile-field{margin-bottom:1rem}
.profile-field label{display:block;font-size:13px;font-weight:500;color:var(--text);margin-bottom:4px}
.profile-field input,.profile-field textarea,.profile-field select{width:100%;padding:10px 13px;border:1.5px solid var(--sand2);border-radius:var(--rs);font-size:14px;font-family:'DM Sans',sans-serif;color:var(--text);background:#fff;resize:vertical;transition:border-color .15s}
.profile-field input:focus,.profile-field textarea:focus,.profile-field select:focus{outline:none;border-color:var(--green)}
.save-btn{background:var(--green);color:#fff;border:none;border-radius:var(--rs);padding:10px 24px;font-size:14px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background .15s}
.save-btn:hover{background:var(--gdark)}

/* ── EMPTY STATE ── */
.empty-state{text-align:center;padding:3rem 2rem;color:var(--tmid)}
.empty-state .empty-icon{font-size:48px;margin-bottom:1rem}
.empty-state h3{font-size:18px;margin-bottom:.5rem;color:var(--text)}
.empty-state p{font-size:14px;max-width:360px;margin:0 auto 1.25rem}

/* ── MODAL ── */
.modal-bg{position:fixed;inset:0;background:rgba(44,36,24,.6);z-index:500;display:none;align-items:center;justify-content:center;padding:1rem}
.modal-bg.open{display:flex}
.modal{background:var(--warm);border-radius:var(--r);max-width:520px;width:100%;padding:2rem;position:relative;max-height:90vh;overflow-y:auto}
.modal-close{position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:20px;cursor:pointer;color:var(--tlight)}
.modal h2{font-size:1.25rem;margin-bottom:1rem}

/* ── NOTIFICATION TOAST ── */
.toast{position:fixed;bottom:1.5rem;right:1.5rem;background:var(--gdark);color:#fff;padding:.875rem 1.25rem;border-radius:var(--rs);font-size:14px;z-index:9999;transform:translateY(100px);opacity:0;transition:all .3s;max-width:320px}
.toast.show{transform:translateY(0);opacity:1}
.toast.error{background:var(--red)}

/* ── COMPLETION SCORE ── */
.score-circle{width:80px;height:80px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Lora',serif;font-size:1.25rem;font-weight:600;color:var(--gdark);background:conic-gradient(var(--green) var(--pct, 0%), var(--sand2) 0%);position:relative}
.score-circle::before{content:'';position:absolute;inset:8px;border-radius:50%;background:var(--warm)}
.score-circle span{position:relative;z-index:1}
</style>
</head>
<body>

<!-- ── AUTH SCREEN ── -->
<div id="auth-screen">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="leaf">🌱</div>
      <h1>Start Your Cause</h1>
      <p>Sign in to your nonprofit portal</p>
    </div>
    <div class="auth-tabs">
      <button class="auth-tab active" onclick="switchTab('signin')">Sign In</button>
      <button class="auth-tab" onclick="switchTab('signup')">Create Account</button>
    </div>
    <div id="auth-error" class="auth-error"></div>
    <div id="auth-success" class="auth-success"></div>

    <!-- Sign In -->
    <div id="tab-signin">
      <div class="field"><label>Email</label><input type="email" id="si-email" placeholder="you@email.com"></div>
      <div class="field"><label>Password</label><input type="password" id="si-password" placeholder="Your password"></div>
      <button class="btn-full btn-green" onclick="signIn()">Sign In</button>
      <div class="divider">or</div>
      <button class="btn-full btn-google" onclick="signInGoogle()">
        <svg width="18" height="18" viewBox="0 0 18 18"><path fill="#4285F4" d="M16.51 8H8.98v3h4.3c-.18 1-.74 1.48-1.6 2.04v2.01h2.6a7.8 7.8 0 002.38-5.88c0-.57-.05-.66-.15-1.18z"/><path fill="#34A853" d="M8.98 17c2.16 0 3.97-.72 5.3-1.94l-2.6-2.04a4.8 4.8 0 01-7.18-2.54H1.83v2.07A8 8 0 008.98 17z"/><path fill="#FBBC05" d="M4.5 10.48A4.8 4.8 0 014.5 7.52V5.45H1.83a8 8 0 000 7.1l2.67-2.07z"/><path fill="#EA4335" d="M8.98 3.18c1.17 0 2.23.4 3.06 1.2l2.3-2.3A8 8 0 001.83 5.45L4.5 7.52A4.8 4.8 0 018.98 3.18z"/></svg>
        Continue with Google
      </button>
      <p style="text-align:center;font-size:13px;color:var(--tlight);margin-top:1rem"><a href="#" onclick="showForgot()">Forgot password?</a></p>
    </div>

    <!-- Sign Up -->
    <div id="tab-signup" style="display:none">
      <div class="field"><label>Full Name</label><input type="text" id="su-name" placeholder="Your full name"></div>
      <div class="field"><label>Email</label><input type="email" id="su-email" placeholder="you@email.com"></div>
      <div class="field"><label>Password</label><input type="password" id="su-password" placeholder="At least 8 characters"></div>
      <button class="btn-full btn-green" onclick="signUp()">Create Account</button>
      <div class="divider">or</div>
      <button class="btn-full btn-google" onclick="signInGoogle()">
        <svg width="18" height="18" viewBox="0 0 18 18"><path fill="#4285F4" d="M16.51 8H8.98v3h4.3c-.18 1-.74 1.48-1.6 2.04v2.01h2.6a7.8 7.8 0 002.38-5.88c0-.57-.05-.66-.15-1.18z"/><path fill="#34A853" d="M8.98 17c2.16 0 3.97-.72 5.3-1.94l-2.6-2.04a4.8 4.8 0 01-7.18-2.54H1.83v2.07A8 8 0 008.98 17z"/><path fill="#FBBC05" d="M4.5 10.48A4.8 4.8 0 014.5 7.52V5.45H1.83a8 8 0 000 7.1l2.67-2.07z"/><path fill="#EA4335" d="M8.98 3.18c1.17 0 2.23.4 3.06 1.2l2.3-2.3A8 8 0 001.83 5.45L4.5 7.52A4.8 4.8 0 018.98 3.18z"/></svg>
        Continue with Google
      </button>
    </div>
  </div>
</div>

<!-- ── PORTAL APP ── -->
<div id="portal-app" style="display:none">
  <div class="app">

    <!-- Sidebar -->
    <nav class="sidebar" id="sidebar">
      <div class="sb-logo">🌱 Start Your Cause</div>
      <div class="sb-nav">
        <div class="sb-section">Main</div>
        <button class="sb-item active" onclick="showPage('dashboard')"><span class="icon">🏠</span> Dashboard</button>
        <button class="sb-item" onclick="showPage('documents')"><span class="icon">📄</span> Documents</button>
        <button class="sb-item" onclick="showPage('calendar')"><span class="icon">📅</span> Compliance Calendar</button>
        <button class="sb-item" onclick="showPage('reminders')"><span class="icon">🔔</span> Reminders</button>
        <div class="sb-section">My Organization</div>
        <button class="sb-item" onclick="showPage('profile')"><span class="icon">🏛️</span> Nonprofit Profile</button>
        <button class="sb-item" onclick="showPage('board')"><span class="icon">👥</span> Board Members</button>
        <div class="sb-section">Account</div>
        <button class="sb-item" onclick="showPage('settings')"><span class="icon">⚙️</span> Settings</button>
      </div>
      <div class="sb-org">
        <strong id="sb-org-name">My Nonprofit</strong>
        <span id="sb-user-email"></span>
      </div>
      <button class="sb-signout" onclick="signOut()">↩ Sign out</button>
    </nav>

    <!-- Main Content -->
    <div class="main">
      <div class="topbar">
        <div style="display:flex;align-items:center;gap:1rem">
          <button class="mob-toggle" onclick="toggleSidebar()">☰</button>
          <h1 id="page-title">Dashboard</h1>
        </div>
        <div class="topbar-right">
          <span class="badge badge-green" id="sub-badge">Active</span>
        </div>
      </div>

      <!-- ── DASHBOARD ── -->
      <div class="portal-page active" id="page-dashboard">
        <div class="grid-4" style="margin-bottom:1.5rem">
          <div class="stat-card"><span class="stat-num" id="stat-docs">0</span><span class="stat-label">Documents generated</span></div>
          <div class="stat-card"><span class="stat-num" id="stat-reminders">0</span><span class="stat-label">Upcoming deadlines</span></div>
          <div class="stat-card"><span class="stat-num" id="stat-overdue">0</span><span class="stat-label">Overdue items</span></div>
          <div class="stat-card"><span class="stat-num" id="stat-complete">0%</span><span class="stat-label">Profile complete</span></div>
        </div>

        <div class="grid-2">
          <div>
            <div class="card">
              <div class="card-title">🏛️ Your Nonprofit</div>
              <div id="dash-org-info" style="font-size:14px;color:var(--tmid)">
                <p>Loading your organization details...</p>
              </div>
              <button class="btn-sm btn-sm-green" style="margin-top:1rem" onclick="showPage('profile')">Edit profile →</button>
            </div>

            <div class="card">
              <div class="card-title">📊 Compliance Score</div>
              <div style="display:flex;align-items:center;gap:1.5rem">
                <div class="score-circle" id="score-circle" style="--pct:0%"><span id="score-num">0%</span></div>
                <div style="flex:1">
                  <div id="score-items" style="font-size:13px;color:var(--tmid)"></div>
                </div>
              </div>
            </div>
          </div>

          <div>
            <div class="card">
              <div class="card-title">🔔 Upcoming Deadlines</div>
              <div id="dash-reminders"></div>
              <button class="btn-sm btn-sm-ghost" style="margin-top:.75rem" onclick="showPage('reminders')">View all reminders →</button>
            </div>

            <div class="card">
              <div class="card-title">📄 Recent Documents</div>
              <div id="dash-docs" style="font-size:13px;color:var(--tmid)"></div>
              <button class="btn-sm btn-sm-ghost" style="margin-top:.75rem" onclick="showPage('documents')">View all documents →</button>
            </div>
          </div>
        </div>
      </div>

      <!-- ── DOCUMENTS ── -->
      <div class="portal-page" id="page-documents">
        <div class="card" style="margin-bottom:1.25rem">
          <div class="card-title">📄 Formation Documents</div>
          <p style="font-size:14px;color:var(--tmid);margin-bottom:1rem">Generated from your intake form answers. Click any document to open and print.</p>
          <div class="doc-grid" id="formation-docs"></div>
        </div>
        <div class="card">
          <div class="card-title">📅 Annual Filing Documents</div>
          <p style="font-size:14px;color:var(--tmid);margin-bottom:.75rem">Select tax year:</p>
          <select id="annual-year-select" style="padding:8px 12px;border:1.5px solid var(--sand2);border-radius:var(--rs);font-family:'DM Sans',sans-serif;font-size:14px;margin-bottom:1rem;background:#fff" onchange="loadAnnualDocs()"></select>
