  renderReminders();
  updateDashReminders();
  document.getElementById('stat-reminders').textContent = allReminders.filter(r => r.status === 'upcoming').length;
  document.getElementById('stat-overdue').textContent = allReminders.filter(r => r.status === 'overdue' || new Date(r.due_date) < new Date() && r.status !== 'completed').length;
}

function renderReminders() {
  const now = new Date();
  const overdue = allReminders.filter(r => new Date(r.due_date) < now && r.status !== 'completed');
  const upcoming = allReminders.filter(r => new Date(r.due_date) >= now && r.status !== 'completed');
  const completed = allReminders.filter(r => r.status === 'completed');

  const renderItem = (r) => {
    const d = new Date(r.due_date);
    const isOverdue = d < now && r.status !== 'completed';
    const daysUntil = Math.ceil((d - now) / (1000*60*60*24));
    const soon = daysUntil <= 7 && daysUntil >= 0;
    return `<div class="reminder-item ${isOverdue?'overdue':soon?'upcoming-soon':''} ${r.status==='completed'?'completed':''}">
      <div class="reminder-date">
        <span class="day">${d.getDate()}</span>
        <span class="month">${d.toLocaleString('default',{month:'short'})}</span>
      </div>
      <div class="reminder-content">
        <h4>${r.title}</h4>
        <p>${r.description||''} ${isOverdue?'<strong style="color:var(--red)">OVERDUE</strong>':soon?`<strong style="color:var(--amber)">${daysUntil} days away</strong>`:''}</p>
        <div class="reminder-actions">
          ${r.status!=='completed'?`<button class="btn-sm btn-sm-green" onclick="markComplete('${r.id}')">✓ Mark complete</button>`:''}
          <button class="btn-sm btn-sm-ghost" onclick="deleteReminder('${r.id}')">Delete</button>
        </div>
      </div>
    </div>`;
  };

  document.getElementById('reminders-overdue').innerHTML = overdue.length ? `<h3 style="font-size:14px;color:var(--red);margin-bottom:.75rem">⚠️ Overdue (${overdue.length})</h3>${overdue.map(renderItem).join('')}` : '';
  document.getElementById('reminders-upcoming').innerHTML = upcoming.length ? `<h3 style="font-size:14px;color:var(--text);margin:.75rem 0">📅 Upcoming (${upcoming.length})</h3>${upcoming.map(renderItem).join('')}` : '<div class="empty-state" style="padding:2rem"><div class="empty-icon">🎉</div><h3>All caught up!</h3><p>No upcoming deadlines. Add a reminder to stay on track.</p></div>';
  document.getElementById('reminders-completed').innerHTML = completed.length ? `<h3 style="font-size:14px;color:var(--tlight);margin:.75rem 0">✓ Completed (${completed.length})</h3>${completed.map(renderItem).join('')}` : '';
}

function updateDashReminders() {
  const now = new Date();
  const upcoming = allReminders.filter(r => r.status !== 'completed').sort((a,b) => new Date(a.due_date)-new Date(b.due_date)).slice(0,4);
  if (!upcoming.length) { document.getElementById('dash-reminders').innerHTML = '<p style="font-size:13px;color:var(--tlight)">No upcoming deadlines.</p>'; return; }
  document.getElementById('dash-reminders').innerHTML = upcoming.map(r => {
    const d = new Date(r.due_date);
    const days = Math.ceil((d - now) / (1000*60*60*24));
    const color = days < 0 ? 'var(--red)' : days <= 7 ? 'var(--amber)' : 'var(--tlight)';
    return `<div style="display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--sand);font-size:13px">
      <span>${r.title}</span>
      <span style="color:${color};font-weight:500;white-space:nowrap;margin-left:.5rem">${days<0?'Overdue':days===0?'Today':days+' days'}</span>
    </div>`;
  }).join('');
}

function openAddReminder() {
  document.getElementById('rem-title').value = '';
  document.getElementById('rem-date').value = '';
  document.getElementById('rem-notes').value = '';
  document.getElementById('reminder-modal').classList.add('open');
}

async function addReminder() {
  const title = document.getElementById('rem-title').value.trim();
  const date = document.getElementById('rem-date').value;
  if (!title || !date) return showToast('Please fill in title and date', true);
  if (!currentNonprofit) return showToast('Please save your nonprofit profile first', true);
  const { error } = await supabase.from('reminders').insert([{
    nonprofit_id: currentNonprofit.id,
    user_id: currentUser.id,
    title,
    due_date: date,
    reminder_type: document.getElementById('rem-type').value,
    description: document.getElementById('rem-notes').value,
    status: 'upcoming',
  }]);
  if (error) showToast('Error adding reminder', true);
  else { showToast('Reminder added!'); closeModal('reminder-modal'); await loadReminders(); renderCalendar(); }
}

async function markComplete(id) {
  await supabase.from('reminders').update({ status: 'completed' }).eq('id', id);
  await loadReminders(); renderCalendar();
}

async function deleteReminder(id) {
  if (!confirm('Delete this reminder?')) return;
  await supabase.from('reminders').delete().eq('id', id);
  await loadReminders(); renderCalendar();
}

// ── CALENDAR ──
function renderCalendar() {
  const year = calDate.getFullYear();
  const month = calDate.getMonth();
  const firstDay = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month+1, 0).getDate();
  const today = new Date();

  document.getElementById('cal-month-title').textContent = calDate.toLocaleString('default', { month: 'long', year: 'numeric' });

  const eventDays = {};
  allReminders.forEach(r => {
    const d = new Date(r.due_date);
    if (d.getFullYear() === year && d.getMonth() === month && r.status !== 'completed') {
      const isOverdue = d < today;
      eventDays[d.getDate()] = isOverdue ? 'overdue' : 'upcoming';
    }
  });

  let html = '';
  for (let i = 0; i < firstDay; i++) html += '<div class="cal-day other-month"></div>';
  for (let d = 1; d <= daysInMonth; d++) {
    const isToday = d === today.getDate() && month === today.getMonth() && year === today.getFullYear();
    const hasEvent = eventDays[d];
    html += `<div class="cal-day ${isToday?'today':''} ${hasEvent?'has-event':''} ${hasEvent==='overdue'?'has-overdue':''}" title="${hasEvent?'Has deadline':''}">${d}</div>`;
  }
  document.getElementById('cal-grid').innerHTML = html;

  // Month reminders
  const monthReminders = allReminders.filter(r => {
    const d = new Date(r.due_date);
    return d.getFullYear() === year && d.getMonth() === month;
  });
  document.getElementById('cal-month-reminders').innerHTML = monthReminders.length
    ? monthReminders.map(r => {
        const d = new Date(r.due_date);
        return `<div style="display:flex;gap:.75rem;align-items:flex-start;padding:.75rem 0;border-bottom:1px solid var(--sand);font-size:13px">
          <span style="font-weight:600;color:var(--gdark);min-width:30px">${d.getDate()}</span>
          <div><strong>${r.title}</strong><br><span style="color:var(--tlight)">${r.reminder_type||'custom'}</span></div>
        </div>`;
      }).join('')
    : '<p style="font-size:13px;color:var(--tlight);padding:.75rem 0">No deadlines this month.</p>';

  // Full annual list
  const allCal = [
    { month: 'January', task: 'Send year-end donor acknowledgment letters', type: 'donor' },
    { month: 'January', task: 'Hold annual board meeting — elect officers, approve budget', type: 'board' },
    { month: 'March', task: 'Gather financial records for Form 990 preparation', type: 'prep' },
    { month: 'May 15', task: 'IRS Form 990 / 990-EZ / 990-N due (calendar-year orgs)', type: 'irs', urgent: true },
    { month: 'May 15', task: 'File Form 8868 extension if needed', type: 'irs' },
    { month: 'Varies', task: 'State annual report due — check your state agency', type: 'state' },
    { month: 'Varies', task: 'Charitable solicitation registration renewal', type: 'state' },
    { month: 'November 15', task: 'Extended Form 990 due', type: 'irs' },
    { month: 'December', task: 'Year-end fundraising push and donor appeals', type: 'donor' },
    { month: 'December 31', task: 'Donor deadline for tax-deductible gifts', type: 'donor' },
  ];
  const typeColors = { irs:'var(--redL)', state:'var(--amberL)', donor:'var(--glight)', board:'#f0f0ff', prep:'var(--sand)' };
  const typeLabels = { irs:'IRS', state:'State', donor:'Donor', board:'Board', prep:'Prep' };
  document.getElementById('full-cal-list').innerHTML = allCal.map(item => `
    <div style="display:flex;align-items:flex-start;gap:1rem;padding:9px 0;border-bottom:1px solid var(--sand);font-size:13px">
      <span style="min-width:90px;color:var(--tmid);font-size:12px">${item.month}</span>
      <span style="flex:1;${item.urgent?'font-weight:500':''}">${item.task}</span>
      <span style="background:${typeColors[item.type]};font-size:11px;font-weight:500;padding:2px 8px;border-radius:10px;flex-shrink:0;color:var(--tmid)">${typeLabels[item.type]}</span>
    </div>
  `).join('');
}

function changeMonth(dir) {
  calDate.setMonth(calDate.getMonth() + dir);
  renderCalendar();
}

