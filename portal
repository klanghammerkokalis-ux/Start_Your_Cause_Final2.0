function openPortalDoc(docId) {
  if (!currentNonprofit && !window.generateAllDocs) return showToast('Please set up your nonprofit profile first', true);
  try {
    const answers = currentNonprofit || {};
    const docs = window.generateAllDocs ? window.generateAllDocs(answers, null) : null;
    if (!docs) return showToast('Document generator not available. Please visit the main site.', true);
    const html = docs[docId];
    if (!html) return;
    const blob = new Blob([html], { type: 'text/html' });
    window.open(URL.createObjectURL(blob), '_blank');
  } catch(e) { showToast('Error generating document', true); }
}

function openAnnualPortalDoc(docId) {
  if (!currentNonprofit) return showToast('Please set up your nonprofit profile first', true);
  try {
    const year = document.getElementById('annual-year-select').value;
    const docs = window.generateYearlyDocs ? window.generateYearlyDocs(currentNonprofit, null, year) : null;
    if (!docs) return showToast('Document generator not available. Please visit the main site.', true);
    const html = docs[docId];
    if (!html) return;
    const blob = new Blob([html], { type: 'text/html' });
    window.open(URL.createObjectURL(blob), '_blank');
  } catch(e) { showToast('Error generating document', true); }
}

// ── NAVIGATION ──
function showPage(page) {
  document.querySelectorAll('.portal-page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.sb-item').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  const titles = { dashboard:'Dashboard', documents:'Documents', calendar:'Compliance Calendar', reminders:'Reminders', profile:'Nonprofit Profile', board:'Board Members', settings:'Settings' };
  document.getElementById('page-title').textContent = titles[page] || page;
  const idx = ['dashboard','documents','calendar','reminders','profile','board','settings'].indexOf(page);
  document.querySelectorAll('.sb-item')[idx]?.classList.add('active');
  document.getElementById('sidebar').classList.remove('open');
}

